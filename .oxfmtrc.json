{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "trailingComma": "es5",
  "bracketSpacing": true,
  "printWidth": 100,
  "tabWidth": 2,
  "singleQuote": false,
  "semi": true,
  "arrowParens": "always",
  "endOfLine": "lf",
  "sortTailwindcss": {
    "config": "./tailwind.config.ts",
    "functions": ["clsx", "cn"]
  },
  "sortPackageJson": false,
  "ignorePatterns": [".claude/**", "drizzle/meta/**"]
}
